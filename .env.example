# Supabase 설정
# https://supabase.com 에서 프로젝트 생성 후 Settings > API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenAI API Key
# https://platform.openai.com 에서 API Key 생성
OPENAI_API_KEY=sk-your_openai_api_key_here

# 내부 테스트용 빠른 로그인 (선택)
# true 로 두면 로그인 화면에 "테스트 학생/교강사 로그인" 버튼이 보입니다. 프로덕션 배포에서는 false 또는 미설정 권장.
# Supabase Dashboard > Authentication > Users 에서 아래 이메일로 사용자를 추가하고, 비밀번호를 qwer1234 로 설정하세요.
# 교강사 계정은 User Metadata에 "role": "instructor", "name": "..." 를 넣거나, supabase/trigger-handle-new-user.sql 적용 후 생성하세요.
NEXT_PUBLIC_ENABLE_TEST_LOGIN=false
# NEXT_PUBLIC_TEST_STUDENT_EMAIL=student-test@vibe-education.app
# NEXT_PUBLIC_TEST_INSTRUCTOR_EMAIL=instructor-test@vibe-education.app

# Supabase에서 Authentication → Bot and Abuse Protection → CAPTCHA 를 켠 경우 필수에 가깝습니다.
# Cloudflare Turnstile에서 만든 사이트 키(Site key). Secret은 Supabase Dashboard에만 넣고, 이 값은 프론트용입니다.
# CAPTCHA를 끄면 설정하지 않아도 됩니다. 문서: https://supabase.com/docs/guides/auth/auth-captcha
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
